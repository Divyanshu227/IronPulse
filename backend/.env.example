PORT=5001
NODE_ENV=production
# Comma-separated list of allowed origins for CORS (frontend domains)
CORS_ORIGIN=https://your-frontend-domain.com
GYMBASE_API_URL=https://gym-base-api-autd.vercel.app/
GYMBASE_API_KEY=your-api-key
# Optional: set FRONTEND_URL if you prefer (used only for documentation)
FRONTEND_URL=https://your-frontend-domain.com